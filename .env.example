# Core
DEMO_MODE=true
APP_ENV=development
SECRET_KEY=your-secret-key-here
ALLOWED_ORIGINS=https://build-opt.site,https://www.build-opt.site,http://localhost:5173

# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=buildopt-super-secret-token
INFLUX_ORG=buildopt
INFLUX_BUCKET=building_metrics

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Johnson Controls Metasys
JCI_METASYS_HOST=https://your-metasys-server.com
JCI_METASYS_USERNAME=api_user
JCI_METASYS_PASSWORD=your-password
JCI_METASYS_VERSION=v4

# BACnet
BACNET_IP=192.168.1.100
BACNET_PORT=47808

# Modbus
MODBUS_HOST=192.168.1.101
MODBUS_PORT=502

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=buildopt
MQTT_PASSWORD=your-mqtt-password

# GCC Features
TIMEZONE=Asia/Dubai
PRAYER_API_KEY=your-aladhan-api-key
LATITUDE=25.2048
LONGITUDE=55.2708
